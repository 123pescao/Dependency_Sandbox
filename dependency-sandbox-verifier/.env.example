# Copy this file to .env and fill in your own values.
# Never commit the .env file — it is listed in .gitignore.

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Matches the docker-compose defaults for local development.
# Use a strong password in any non-local environment.
DATABASE_URL="postgresql://dsv_user:CHANGE_ME@localhost:5432/dsv"

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── OPA (Open Policy Agent) ──────────────────────────────────────────────────
# Default: http://localhost:8181 — set only if OPA runs elsewhere.
# OPA_URL="http://localhost:8181"

# ── AI analysis ──────────────────────────────────────────────────────────────
# Set to use real OpenAI GPT-4 analysis. Leave unset to use the built-in stub.
OPENAI_API_KEY="SET_IN_ENV"

# ── GitHub integration ───────────────────────────────────────────────────────
# Personal access token or GitHub App installation token for PR comments.
GITHUB_TOKEN="SET_IN_ENV"

# ── GitHub webhook ────────────────────────────────────────────────────────────
# The secret you configure in GitHub App settings → Webhook → Secret.
WEBHOOK_SECRET="SET_IN_ENV"

# ── Dashboard ────────────────────────────────────────────────────────────────
# API base URL for the Next.js dashboard → API proxy rewrite.
# API_URL="http://localhost:3000"

# ── CLI ──────────────────────────────────────────────────────────────────────
# API base URL for CLI report/replay commands.
# DSV_API_URL="http://localhost:3000"
